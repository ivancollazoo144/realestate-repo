# Copy to .env and fill in. Never commit .env.

# ----- Google -----
# Path to OAuth client credentials JSON downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=./credentials.json
# Path where the OAuth refresh token is cached after first auth
GOOGLE_TOKEN_PATH=./token.json
# Email of the dedicated Gmail account that holds outreach drafts
OUTREACH_GMAIL_ADDRESS=

# ----- Google Sheet -----
# Name of the workbook (created on first run if missing)
SHEET_WORKBOOK_NAME=PR Real Estate Leads
# Worksheet tab names
SHEET_TAB_LISTINGS=Listings
SHEET_TAB_SMS_DRAFTS=SMS Drafts

# ----- Database -----
DB_PATH=./data/realestate.db

# ----- Scraping -----
# Comma-separated list of municipios or zips to focus on (empty = whole island)
PR_FOCUS_MUNICIPIOS=
# Hard filter thresholds
MIN_SALE_PRICE=150000
MIN_RENT_PRICE=1500

# ----- Zillow -----
# Residential proxy URL (e.g., http://user:pass@host:port). Empty = no proxy (only safe for very low volume).
ZILLOW_PROXY_URL=

# ----- Facebook -----
# Path to Playwright storage_state.json (created after first manual login)
FB_STORAGE_STATE_PATH=./storage_state.json

# ----- Outreach -----
# Cooldown in days before re-contacting the same phone or email
OUTREACH_COOLDOWN_DAYS=14
# Set to "true" to actually create Gmail drafts. "false" = log only (safe default while developing)
ENABLE_GMAIL_DRAFTS=false
